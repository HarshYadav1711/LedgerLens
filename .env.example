# Application
APP_NAME=LedgerLens
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql://ledgerlens:ledgerlens@postgres:5432/ledgerlens

# Celery / Redis
REDIS_URL=redis://redis:6379/0

# Ollama (local LLM)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2

# Processing
UPLOAD_DIR=/app/uploads
LLM_BATCH_SIZE=25
LLM_MAX_RETRIES=3
LLM_RETRY_BASE_DELAY=2.0
